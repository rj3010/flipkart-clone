{
  "name": "mini-flipkart",
  "private": true,
  "scripts": {
    "lint": "pnpm -r lint",
    "build": "pnpm -r build",
    "dev:client": "pnpm --filter client dev",
    "dev:server": "pnpm --filter server dev",
    "prepare": "husky",
    "lint:fix": "pnpm -r lint:fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check"
  },
  "lint-staged": {
    "apps/server/src/**/*.js": [
      "eslint --fix",
      "prettier --write"
    ],
    "apps/client/src/**/*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "prettier": "^3.8.3"
  }
}
